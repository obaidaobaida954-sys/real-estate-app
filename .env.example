# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is already in .gitignore.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Must match an Auth user in your Supabase project


# Google Maps API — optional (property map feature)
VITE_GOOGLE_MAPS_API_KEY=

# Set to "true" to enable debug logging locally
VITE_DEBUG_LOGS=false

# Set to "true" to enable remote error tracking
VITE_ERROR_TRACKING=false
